# CJAirPort 환경변수 템플릿 — 실제 값을 여기에 넣지 마세요 (키 이름만).
# 실제 .env 는 커밋 금지 (하네스 훅이 차단). 배포 시크릿 매니저를 사용하세요.

# --- DB (MSSQL) ---
DB_MSSQL_URL=
DB_MSSQL_USERNAME=
DB_MSSQL_PASSWORD=

# --- DB (MariaDB) ---
DB_MARIADB_URL=
DB_MARIADB_USERNAME=
DB_MARIADB_PASSWORD=

# --- Suprema BiostarX ---
BIOSTAR_BASE_URL=
BIOSTAR_API_KEY=

# --- App ---
SPRING_PROFILES_ACTIVE=dev
